generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  userId             Int     @id @default(autoincrement()) @map("user_id")
  name               String // O nome real ou apelido (pode ter espaços)
  username           String  @unique // O "arroba", usado na URL
  email              String  @unique
  senha_hash         String
  bio                String?
  avatar_url         String?
  background_url     String?
  wishlist_is_public Boolean @default(true)

  // Relacionamentos N:1
  biblioteca LibraryEntry[]
  wishlist   WishlistEntry[]
  reviews    Review[]
  listas     List[]

  comentarios     Comment[]
  notificacoes    Notification[]
  favoritos       FavoriteGame[]
  curtidas        ReviewLike[]
  curtidasComents CommentLike[]

  // Auto-relacionamento de Seguidores
  seguidores UserFollow[] @relation("Seguido")
  seguindo   UserFollow[] @relation("Seguidor")

  @@map("users")
}

model Game {
  id_igdb            Int     @id
  name               String
  bio                String? // Sinopse/Summary do jogo
  cover_url          String? // Capa em alta resolução
  background_url     String? // Artwork 1080p para o fundo
  release_year       Int? // Ano de lançamento
  developer          String? // Empresa desenvolvedora principal
  genre              String? // Lista de gêneros (ex: "RPG, Adventure")
  platforms          String? // Lista de plataformas (ex: "PC, PS5")
  rating             Float? // Nota do jogo (ex: 4.7)
  rating_count       Int? // Quantidade de avaliações
  similar_games_json String? // Lista de jogos similares em formato JSON

  // Relacionamentos N:1 (Mantidos perfeitamente iguais aos seus)
  biblioteca LibraryEntry[]
  reviews    Review[]
  listItems  ListItem[]
  favoritos  FavoriteGame[]
  wishlist   WishlistEntry[]

  @@map("games")
}

model LibraryEntry {
  status            String
  marco_campanha    Boolean   @default(false)
  marco_secundarias Boolean   @default(false)
  started_at        DateTime?
  finished_at       DateTime?

  userId  Int @map("user_id")
  id_igdb Int

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)
  game Game @relation(fields: [id_igdb], references: [id_igdb], onDelete: Cascade)

  @@id([userId, id_igdb])
  @@map("library_entries")
}

model WishlistEntry {
  addedAt DateTime @default(now()) @map("added_at")

  userId  Int @map("user_id")
  id_igdb Int

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)
  game Game @relation(fields: [id_igdb], references: [id_igdb], onDelete: Cascade)

  @@id([userId, id_igdb])
  @@map("wishlist_entries")
}

model List {
  listId   Int     @id @default(autoincrement()) @map("list_id")
  title    String
  summary  String?
  isPublic Boolean @default(true) @map("is_public")

  userId Int  @map("user_id")
  user   User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  listItems ListItem[]

  @@map("lists")
}

model ListItem {
  ordem Int

  listId  Int @map("list_id")
  id_igdb Int

  list List @relation(fields: [listId], references: [listId], onDelete: Cascade)
  game Game @relation(fields: [id_igdb], references: [id_igdb], onDelete: Cascade)

  @@id([listId, id_igdb])
  @@map("list_items")
}

model Review {
  reviewId   Int      @id @default(autoincrement()) @map("review_id")
  nota       Float
  reviewText String?  @map("review_text")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  userId  Int @map("user_id")
  id_igdb Int

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)
  game Game @relation(fields: [id_igdb], references: [id_igdb], onDelete: Cascade)

  comentarios Comment[]
  curtidas    ReviewLike[]

  @@unique([userId, id_igdb]) // 1 usuário só faz 1 review por jogo
  @@map("reviews")
}

model Comment {
  commentID Int      @id @default(autoincrement()) @map("comment_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  userId   Int @map("user_id")
  reviewId Int @map("review_id")

  user   User   @relation(fields: [userId], references: [userId], onDelete: Cascade)
  review Review @relation(fields: [reviewId], references: [reviewId], onDelete: Cascade)

  curtidas CommentLike[]

  @@map("comments")
}

model ReviewLike {
  createdAt DateTime @default(now()) @map("created_at")

  userId   Int @map("user_id")
  reviewId Int @map("review_id")

  user   User   @relation(fields: [userId], references: [userId], onDelete: Cascade)
  review Review @relation(fields: [reviewId], references: [reviewId], onDelete: Cascade)

  // O usuário só pode curtir a mesma review 1 vez
  @@id([userId, reviewId])
  @@map("review_likes")
}

model CommentLike {
  createdAt DateTime @default(now()) @map("created_at")

  userId    Int @map("user_id")
  commentID Int @map("comment_id")

  user    User    @relation(fields: [userId], references: [userId], onDelete: Cascade)
  comment Comment @relation(fields: [commentID], references: [commentID], onDelete: Cascade)

  // O usuário só pode curtir o mesmo comentário 1 vez
  @@id([userId, commentID])
  @@map("comment_likes")
}

model UserFollow {
  createdAt DateTime @default(now()) @map("created_at")

  followerID  Int @map("follower_id")
  followingID Int @map("following_id")

  seguidor User @relation("Seguidor", fields: [followerID], references: [userId], onDelete: Cascade)
  seguido  User @relation("Seguido", fields: [followingID], references: [userId], onDelete: Cascade)

  @@id([followerID, followingID])
  @@map("user_follows")
}

model Notification {
  notificationID Int      @id @default(autoincrement()) @map("notification_id")
  type           String // Ex: "NEW_FOLLOWER", "NEW_LIKE"
  isRead         Boolean  @default(false) @map("is_read")
  createdAt      DateTime @default(now()) @map("created_at")

  userId Int  @map("user_id")
  user   User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("notifications")
}

model FavoriteGame {
  slot Int // Posição de 1 a 4 lá no Front-end

  userId  Int @map("user_id")
  id_igdb Int

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)
  game Game @relation(fields: [id_igdb], references: [id_igdb], onDelete: Cascade)

  // Garante que o usuário não coloque 2 jogos no mesmo slot
  @@id([userId, slot])
  @@map("favorite_games")
}
