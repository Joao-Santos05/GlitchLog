generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") // Certifique-se de ter isso no seu .env
}

// Enum para padronizar os status e evitar erros de digitação
enum LogStatus {
  QUERO_JOGAR
  JOGANDO
  FINALIZADO
  ABANDONADO
}

model User {
  userId     Int      @id @default(autoincrement()) @map("user_id")
  name       String         
  username   String   @unique 
  email      String   @unique
  senha_hash String 
  bio        String? 
  avatar_url String?

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relacionamentos N:1
  biblioteca   LibraryEntry[]
  reviews      Review[]
  listas       List[]
  
  comentarios  Comment[]
  notificacoes Notification[]
  favoritos    FavoriteGame[]
  curtidas     ReviewLike[]

  // Auto-relacionamento de Seguidores
  seguidores UserFollow[] @relation("Seguido")
  seguindo   UserFollow[] @relation("Seguidor")

  @@map("users")
}

model Game {
  id_igdb            Int      @id
  name               String
  bio                String?  
  cover_url          String?  
  background_url     String?  
  release_date       DateTime? @map("release_date") // Atualizado para DateTime
  developer          String?  
  genre              String?  
  platforms          String?  
  rating             Float?   
  rating_count       Int?     
  similar_games_json String?  

  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // Relacionamentos N:1
  biblioteca         LibraryEntry[]
  reviews            Review[]
  listItems          ListItem[]
  favoritos          FavoriteGame[]

  @@map("games")
}

model LibraryEntry {
  status            LogStatus @default(QUERO_JOGAR) // Usando o Enum
  marco_campanha    Boolean   @default(false)
  marco_secundarias Boolean   @default(false)
  started_at        DateTime?
  finished_at       DateTime?

  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  userId  Int @map("user_id")
  id_igdb Int     

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)
  game Game @relation(fields: [id_igdb], references: [id_igdb], onDelete: Cascade)

  @@id([userId, id_igdb])
  @@map("library_entries")
}

model List {
  listId    Int      @id @default(autoincrement()) @map("list_id")
  title     String
  summary   String?
  isPublic  Boolean  @default(true) @map("is_public")
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId Int @map("user_id")
  user   User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  listItems ListItem[]

  @@map("lists")
}

model ListItem {
  ordem Int
  
  listId  Int @map("list_id")
  id_igdb Int     

  list List @relation(fields: [listId], references: [listId], onDelete: Cascade)
  game Game @relation(fields: [id_igdb], references: [id_igdb], onDelete: Cascade)

  @@id([listId, id_igdb])
  @@map("list_items")
}

model Review {
  reviewId   Int      @id @default(autoincrement()) @map("review_id")
  nota       Float   
  reviewText String?  @map("review_text")
  
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  userId     Int      @map("user_id")
  id_igdb    Int      

  user       User     @relation(fields: [userId], references: [userId], onDelete: Cascade)
  game       Game     @relation(fields: [id_igdb], references: [id_igdb], onDelete: Cascade)

  comentarios Comment[]
  curtidas    ReviewLike[]

  @@unique([userId, id_igdb]) 
  @@map("reviews")
}

model Comment {
  commentID Int      @id @default(autoincrement()) @map("comment_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId   Int @map("user_id")
  reviewId Int @map("review_id")

  user   User   @relation(fields: [userId], references: [userId], onDelete: Cascade)
  review Review @relation(fields: [reviewId], references: [reviewId], onDelete: Cascade)

  @@map("comments")
}

model ReviewLike {
  createdAt DateTime @default(now()) @map("created_at")

  userId   Int @map("user_id")
  reviewId Int @map("review_id")

  user   User   @relation(fields: [userId], references: [userId], onDelete: Cascade)
  review Review @relation(fields: [reviewId], references: [reviewId], onDelete: Cascade)

  @@id([userId, reviewId])
  @@map("review_likes")
}

model UserFollow {
  createdAt DateTime @default(now()) @map("created_at")

  followerID  Int @map("follower_id")
  followingID Int @map("following_id")

  seguidor User @relation("Seguidor", fields: [followerID], references: [userId], onDelete: Cascade)
  seguido  User @relation("Seguido", fields: [followingID], references: [userId], onDelete: Cascade)

  @@id([followerID, followingID])
  @@map("user_follows")
}

model Notification {
  notificationID Int      @id @default(autoincrement()) @map("notification_id")
  type           String   
  isRead         Boolean  @default(false) @map("is_read")
  createdAt      DateTime @default(now()) @map("created_at")

  userId Int @map("user_id")
  user   User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("notifications")
}

model FavoriteGame {
  slot Int 

  userId  Int @map("user_id")
  id_igdb Int

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)
  game Game @relation(fields: [id_igdb], references: [id_igdb], onDelete: Cascade)

  @@id([userId, slot]) 
  @@map("favorite_games")
}
