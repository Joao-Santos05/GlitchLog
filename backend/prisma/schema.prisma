
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  userId     Int     @id @default(autoincrement()) @map("user_id")
  name       String
  email      String  @unique
  senha_hash String 
  bio        String? 
  avatar_url String?

  // Relacionamentos N:1
  biblioteca    LibraryEntry[]
  reviews       Review[]
  listas        List[]
  
  comentarios   Comment[]
  notificacoes  Notification[]
  favoritos     FavoriteGame[]
  curtidas      ReviewLike[]

  // Auto-relacionamento de Seguidores
  seguidores UserFollow[] @relation("Seguido")
  seguindo   UserFollow[] @relation("Seguidor")

  @@map("users")
}

model Game {
  id_igdb Int    @id
  name    String

  // Relacionamentos N:1
  biblioteca LibraryEntry[]
  reviews    Review[]
  listItems  ListItem[]
  favoritos  FavoriteGame[] // Jogo pode estar nos favoritos de vários usuários

  @@map("games")
}

model LibraryEntry {
  status            String    @default("Quero Jogar")
  marco_campanha    Boolean   @default(false)
  marco_secundarias Boolean   @default(false)
  started_at        DateTime?
  finished_at       DateTime?

  userId  Int @map("user_id")
  id_igdb Int     

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)
  game Game @relation(fields: [id_igdb], references: [id_igdb], onDelete: Cascade)

  @@id([userId, id_igdb])
  @@map("library_entries")
}

model List {
  listId   Int     @id @default(autoincrement()) @map("list_id")
  title    String
  summary  String?
  isPublic Boolean @default(true) @map("is_public")
  
  userId Int @map("user_id")
  user   User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  listItems ListItem[]

  @@map("lists")
}

model ListItem {
  ordem Int
  
  listId  Int @map("list_id")
  id_igdb Int     

  list List @relation(fields: [listId], references: [listId], onDelete: Cascade)
  game Game @relation(fields: [id_igdb], references: [id_igdb], onDelete: Cascade)

  @@id([listId, id_igdb])
  @@map("list_items")
}

model Review {
  reviewId   Int     @id @default(autoincrement()) @map("review_id")
  nota       Int
  reviewText String? @map("review_text")
  
  userId  Int @map("user_id")
  id_igdb Int     

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)
  game Game @relation(fields: [id_igdb], references: [id_igdb], onDelete: Cascade)

  comentarios Comment[]
  curtidas    ReviewLike[]

  @@unique([userId, id_igdb]) // 1 usuário só faz 1 review por jogo
  @@map("reviews")
}

model Comment {
  commentID Int      @id @default(autoincrement()) @map("comment_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  userId   Int @map("user_id")
  reviewId Int @map("review_id")

  user   User   @relation(fields: [userId], references: [userId], onDelete: Cascade)
  review Review @relation(fields: [reviewId], references: [reviewId], onDelete: Cascade)

  @@map("comments")
}

model ReviewLike {
  createdAt DateTime @default(now()) @map("created_at")

  userId   Int @map("user_id")
  reviewId Int @map("review_id")

  user   User   @relation(fields: [userId], references: [userId], onDelete: Cascade)
  review Review @relation(fields: [reviewId], references: [reviewId], onDelete: Cascade)

  // O usuário só pode curtir a mesma review 1 vez
  @@id([userId, reviewId])
  @@map("review_likes")
}

model UserFollow {
  createdAt DateTime @default(now()) @map("created_at")

  followerID  Int @map("follower_id")
  followingID Int @map("following_id")

  seguidor User @relation("Seguidor", fields: [followerID], references: [userId], onDelete: Cascade)
  seguido  User @relation("Seguido", fields: [followingID], references: [userId], onDelete: Cascade)

  @@id([followerID, followingID])
  @@map("user_follows")
}

model Notification {
  notificationID Int      @id @default(autoincrement()) @map("notification_id")
  type           String   // Ex: "NEW_FOLLOWER", "NEW_LIKE"
  isRead         Boolean  @default(false) @map("is_read")
  createdAt      DateTime @default(now()) @map("created_at")

  userId Int @map("user_id")
  user   User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("notifications")
}

model FavoriteGame {
  slot Int // Posição de 1 a 4 lá no Front-end

  userId  Int @map("user_id")
  id_igdb Int

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)
  game Game @relation(fields: [id_igdb], references: [id_igdb], onDelete: Cascade)

  // Garante que o usuário não coloque 2 jogos no mesmo slot
  @@id([userId, slot]) 
  @@map("favorite_games")
}